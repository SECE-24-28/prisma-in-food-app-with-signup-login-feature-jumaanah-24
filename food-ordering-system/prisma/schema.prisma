generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model customers {
  customer_id   Int        @id @default(autoincrement())
  customer_name String     @db.VarChar(30)
  phone         String     @db.VarChar(20)
  address       String     @db.VarChar(50)
  orders        orders[]
  payments      payments[]
}

model delivery_partners {
  partner_id   Int      @id @default(autoincrement())
  partner_name String   @db.VarChar(20)
  phone        String   @db.VarChar(20)
  vehicle      String   @db.VarChar(20)
  orders       orders[]
}

model menu_items {
  item_id       Int         @id @default(autoincrement())
  item_name     String?     @db.VarChar(20)
  price         String      @db.VarChar(20)
  restaurant_id Int
  description   String?
  category      String?     @db.VarChar(20)
  image_url     String?
  restaurants   restaurants @relation(fields: [restaurant_id], references: [restaurant_id], onDelete: NoAction, onUpdate: NoAction)
}

model orders {
  order_id          Int               @id @default(autoincrement())
  customer_id       Int
  partner_id        Int
  restaurant_id     Int
  total_price       Int
  status            String?           @db.VarChar(50)
  customers         customers         @relation(fields: [customer_id], references: [customer_id], onDelete: NoAction, onUpdate: NoAction)
  delivery_partners delivery_partners @relation(fields: [partner_id], references: [partner_id], onDelete: NoAction, onUpdate: NoAction)
  restaurants       restaurants       @relation(fields: [restaurant_id], references: [restaurant_id], onDelete: NoAction, onUpdate: NoAction)
  payments          payments[]
}

model payments {
  payment_id   Int       @id @default(autoincrement())
  payment_mode String?   @db.VarChar(30)
  amount       Decimal?  @db.Decimal(10, 2)
  payment_date DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  status       String?   @db.VarChar(30)
  order_id     Int
  customer_id  Int
  customers    customers @relation(fields: [customer_id], references: [customer_id], onDelete: NoAction, onUpdate: NoAction)
  orders       orders    @relation(fields: [order_id], references: [order_id], onDelete: NoAction, onUpdate: NoAction)
}

model restaurants {
  restaurant_id   Int          @id @default(autoincrement())
  restaurant_name String       @db.VarChar(30)
  location        String       @db.VarChar(30)
  opening_hrs     String       @db.VarChar(20)
  closing_hrs     String       @db.VarChar(20)
  menu_items      menu_items[]
  orders          orders[]
}

model users {
  user_id  Int    @id @default(autoincrement())
  username String @unique @db.VarChar(50)
  password String @db.VarChar(255)
  email    String @unique @db.VarChar(100)
}
